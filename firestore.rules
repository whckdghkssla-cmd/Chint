rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // For sandboxed applet environments, we allow read and write (create, update, delete)
    // and rely on client-side passcode authentication for UI safety.
    match /inventory/{itemId} {
      allow read, write: if true;
    }

    match /inquiries/{inquiryId} {
      allow read, write: if true;
    }
  }
}
